{
  "name": "@repui/core",
  "version": "0.1.0-beta.1",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test test/**/*.test.ts",
    "coverage": "c8 --reporter=text --reporter=html npm test",
    "test:browser": "npm run build && playwright test",
    "test:browser:docker": "docker run --rm --ipc=host -v \"$PWD\":/work -v rui-playwright-node-modules:/work/node_modules -w /work mcr.microsoft.com/playwright:v1.61.1-noble bash -lc 'npm ci --ignore-scripts && npx playwright test'",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/jsdom": "^21.1.7",
    "c8": "^10.1.3",
    "jsdom": "^26.0.0",
    "@playwright/test": "^1.61.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
